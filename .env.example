# Copy this file to .env.local and fill in your values
NEXT_PUBLIC_API_URL=https://your-railway-api.up.railway.app

# DEFAULT Supabase project (the original single project)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Multi-project routing: KINEMATIC Supabase project. The dashboard resolves a
# user's project from their email at login (backend /auth/project-for-email),
# sends X-Kinematic-Project on every request, and uses the matching URL/anon
# key for realtime + server proxies. Leave blank to run single-project as today.
NEXT_PUBLIC_KINEMATIC_SUPABASE_URL=
NEXT_PUBLIC_KINEMATIC_SUPABASE_ANON_KEY=
KINEMATIC_SUPABASE_SERVICE_ROLE_KEY=

NEXTAUTH_SECRET=generate-a-32-char-secret
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Kinematic
NEXT_PUBLIC_APP_VERSION=1.0.0
